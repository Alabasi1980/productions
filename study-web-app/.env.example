# انسخ هذا الملف إلى .env.local وضع القيم الحقيقية هناك.
# لا تضع المفتاح داخل التطبيق أو داخل المستودع.

OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
# مودل خفيف اقتصادي للأسئلة المباشرة وإعادة الصياغة السريعة.
OPENAI_MODEL=gpt-5.4-nano
# مودل أقوى للأسئلة الثقيلة مثل التحليل المقارن وخطط التنفيذ والمخاطر.
OPENAI_HEAVY_MODEL=gpt-5.4-mini
# فعّل التوجيه الذكي للتصعيد التلقائي بين المودلين.
OPENAI_SMART_ROUTING=true
PORT=8787
OPENAI_WEB_SEARCH=true
ALLOWED_ORIGIN=*
OPENAI_BASE_URL=https://api.openai.com/v1
